<?xml version="1.0" encoding="utf-8"?>
<!--
  For more information on how to configure your ASP.NET application, please visit
  https://go.microsoft.com/fwlink/?LinkId=301880
  -->
<configuration>
	<configSections>
		<section name="PageTypeImageSection" type="netfw48.App_Start.PageTypeImagesConfigSection"/>
	</configSections>
  <appSettings>
	
	<!-- Start XPMLITE --> 
	<add key="client_id" value="7c236b33-86cf-41eb-8b78-b119025a9f8c" />
	<add key="redirect_uri" value="https://preview.tridiondemo.com" />
	<add key="openapi_baseurl" value="https://sites.tridiondemo.com/api/v3.0" />
	<add key="authorization_baseurl" value="https://access.tridiondemo.com/access-management/connect" />
	<add key="contentServiceUrl" value="https://sites.tridiondemo.com:8081/cd/api" />
  <add key="experience_space_url" value="https://sites.tridiondemo.com/ui/editor" />

    <!-- End XPMLITE -->
	
    <add key="webpages:Version" value="3.0.0.0" />
    <add key="webpages:Enabled" value="false" />
    <add key="ClientValidationEnabled" value="true" />
    <add key="UnobtrusiveJavaScriptEnabled" value="true" />
    <!-- Tridion Discovery Service URL -->
    <add key="discovery-service-uri" value="https://sites.tridiondemo.com:8082/discovery.svc" />
      <!-- Tridion Preview Service Capability -->
    <add key="previewWebServiceCapability" value="PreviewWebServiceCapability" />
    <!-- If Discovery is OAuth-protected, also add: -->
    <!-- <add key="oauth-enabled" value="true" /> -->
    <!-- <add key="oauth-client-id" value="cduser" /> -->
    <!-- <add key="oauth-client-secret" value="CDUserP@ssword" /> -->
    <!-- Publication to serve content from (Option A) -->
    <!-- Remove this key once Topology Manager is configured -->
    <add key="DD4T.PublicationId" value="7" />
    <!-- Namespace(s) where your controllers live -->
    <add key="Dyndle.ControllerNamespaces" value="DyndleWebApp.Controllers,Dyndle.Modules.Core.Controllers" />
    <!-- Namespace(s) where your view models live -->
    <add key="Dyndle.ViewModelNamespaces" value="DyndleWebApp.Models" />
    <!-- Welcome file for Structure Groups (directories) -->
    <add key="DD4T.WelcomeFile" value="index.html" />
    <!-- Enable DD4T/Dyndle logging -->
    <add key="DD4T.LogLevel" value="Error" />
    <!-- ✅ ADD THIS — tells DD4T the broker content is JSON format -->
    <add key="DD4T.SerializationFormat" value="JSON" />
    <!-- ✅ ADD THIS — prevents MaxDepth errors with complex nested JSON -->
    <add key="DD4T.JsonSerializerMaxDepth" value="128" />
    <!-- ✅ ADD THIS — tells Dyndle which view to use when ViewName is empty -->
    <add key="Dyndle.DefaultRegionView" value="Region" />
    <!-- ✅ Pattern that matches binary/image URLs -->
    <add key="DD4T.BinaryUrlPattern" value="^/media/.*\.(jpg|jpeg|png|gif|svg|pdf)$" />
    <!-- Use Dyndle's absolute physical path override for binary assets -->
    <!-- Your files are in BinaryData\media\ so use this: -->
    <add key="DD4T.BinaryFileSystemPath" value="~/BinaryData" />
    <add key="DD4T.ContentProviderEndPoint" value="https://sites.tridiondemo.com:8081/cd/api" />
    <!-- Disable cache temporarily for debugging -->
    <add key="DD4T.CacheSettings.Binary" value="0" />
  


    <!--<add key="Includes.HeaderPageUrl" value="dyndel_header.html" />-->
    <!--<add key="Dyndle.IncludesUrl" value="/dyndle_header.html" />-->
    <add key="Dyndle.IncludesUrlMask" value="/{0}.html" />
    <!--<add key="Includes.FooterPageUrl" value="footer.html" />-->


    <!-- Only needed if you use a different location -->
    <add key="Navigation.SourceUrl" value="/system/navigation.json" />
    
  </appSettings>
  <system.webServer>
    <!-- ✅ This is the critical section — forces all requests through MVC -->
    <handlers>
      <!-- Remove the static file handler for extensionless and .html URLs -->
      <remove name="StaticFile" />
      <remove name="ExtensionlessUrlHandler-Integrated-4.0" />

      <!-- ✅ Static files (.css, .js, .png, .jpg, .gif, .svg, .woff, etc.)
         served directly by IIS — NOT through managed pipeline -->
      <add name="StaticFile"
           path="*"
           verb="*"
           modules="StaticFileModule,DefaultDocumentModule,DirectoryListingModule"
           resourceType="Either"
           requireAccess="Read" />

      <!-- ✅ Extensionless URLs and .html go through ASP.NET/Dyndle -->
      <add name="ExtensionlessUrlHandler-Integrated-4.0"
           path="*."
           verb="GET,HEAD,POST,DEBUG"
           type="System.Web.Handlers.TransferRequestHandler"
           preCondition="integratedMode,runtimeVersionv4.0" />

      <!-- ✅ .html pages go through ASP.NET/Dyndle -->
      <add name="HtmlHandler"
           path="*.html"
           verb="GET,HEAD"
           type="System.Web.Handlers.TransferRequestHandler"
           preCondition="integratedMode,runtimeVersionv4.0" />


    </handlers>
    <validation validateIntegratedModeConfiguration="false" />
    <!-- ✅ Required for images/binaries to be served from broker -->
    <modules runAllManagedModulesForAllRequests="true">
      <!--<add name="BinaryModule"
             type="DD4T.Web.Binaries.BinaryDistributionModule, DD4T.Web" />-->
      <!-- ✅ ADD — self-contained, fetches from Content Service directly -->
      <add name="BinaryModule" type="DyndleWebApp.Infrastructure.BinaryProxyModule, DyndleWebApp" />
    </modules>

    <!-- ✅ Ensure IIS serves static files from Content folder -->
    <staticContent>
      <remove fileExtension=".woff" />
      <mimeMap fileExtension=".woff"  mimeType="font/woff" />

      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />

      <remove fileExtension=".svg" />
      <mimeMap fileExtension=".svg"   mimeType="image/svg+xml" />
    </staticContent>
    
  </system.webServer>
  <system.web>
    <compilation debug="true" targetFramework="4.8" />
    <httpRuntime targetFramework="4.8" />


    <customErrors mode="On" defaultRedirect="~/Views/Errors/500.html">
      <error statusCode="404" redirect="~/Views/Errors/404.html" />
      <error statusCode="500" redirect="~/Views/Errors/500.html" />
    </customErrors>
    
  </system.web>
  <runtime>
 
